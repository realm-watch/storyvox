<?xml version="1.0" encoding="utf-8"?>
<!-- Library Nocturne launcher background: a warm-dark vellum surface lit
     by candlelight glow at upper-right and a brass hearth-glow at lower-
     center, framing the foreground glyph. Two layered radial gradients
     give the impression of depth without raster blur. Base color matches
     the in-app Library Nocturne surface (#0E0C12). -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Base — deep warm dark -->
    <path
        android:fillColor="#0E0C12"
        android:pathData="M0,0h108v108h-108z" />

    <!-- Lower-center hearth-glow — brass warming the page from below.
         A radial bloom whose center sits below the visible canvas so its
         falloff cradles the open book without dominating it. -->
    <path
        android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="92"
                android:gradientRadius="68">
                <item android:offset="0.0" android:color="#3A2A18" />
                <item android:offset="0.5" android:color="#1A1018" />
                <item android:offset="1.0" android:color="#00000000" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Upper-right candlelight bloom — the existing motif, intensified
         a touch and shifted closer to the corner so it reads as a single
         off-canvas candle illuminating the page. -->
    <path
        android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="98"
                android:centerY="10"
                android:gradientRadius="78">
                <item android:offset="0.0" android:color="#7AB48C5A" />
                <item android:offset="0.55" android:color="#1FB48C5A" />
                <item android:offset="1.0" android:color="#00000000" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Constellation — three faint brass stars in the upper half, small
         enough to read as ambient light, not detail. -->
    <path
        android:fillColor="#66C9A774"
        android:pathData="M86,22 m-1,0 a1,1 0 1,0 2,0 a1,1 0 1,0 -2,0" />
    <path
        android:fillColor="#44C9A774"
        android:pathData="M18,12 m-0.7,0 a0.7,0.7 0 1,0 1.4,0 a0.7,0.7 0 1,0 -1.4,0" />
    <path
        android:fillColor="#55C9A774"
        android:pathData="M14,40 m-0.8,0 a0.8,0.8 0 1,0 1.6,0 a0.8,0.8 0 1,0 -1.6,0" />

</vector>
