<?xml version="1.0" encoding="utf-8"?>
<!-- Library Nocturne launcher foreground: an open brass-bound book with
     gilded pages, three ascending sound-wave arcs that rise from the
     gutter, and a small candle flame above — Library Nocturne's signature
     motif. A subtle brass halo behind the book reads as candleglow on
     vellum without raster blur (achieved via a layered radial fill).

     Anchored in the 72dp safe zone of the 108dp adaptive canvas (center
     54×54, glyph radius ~30dp). Strokes and fills use the in-app brass
     palette: warm-brass #B48C5A, lit-brass #C9A774, gilt #E0C8A0, deep-
     gilt #7A5A30. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Brass halo behind the book — radial bloom centered on the spine,
         very subtle, gives the glyph depth on light & dark launchers. -->
    <path
        android:pathData="M54,62 m-32,0 a32,32 0 1,0 64,0 a32,32 0 1,0 -64,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="62"
                android:gradientRadius="32">
                <item android:offset="0.0" android:color="#55E0C8A0" />
                <item android:offset="0.6" android:color="#15B48C5A" />
                <item android:offset="1.0" android:color="#00000000" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Page shadow — a darker shape just behind the open book to give
         it lift, suggesting it floats above the surface. -->
    <path
        android:fillColor="#33000000"
        android:pathData="M26,84 C36,80 72,80 82,84 L80,87 C70,84 38,84 28,87 Z" />

    <!-- Left page — gilded gradient from warm brass to deep-gilt at the
         spine edge, simulating a curved page catching the light. -->
    <path
        android:pathData="M28,62 C30,57 38,53 50,55 L50,82 C38,80 30,82 28,84 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="28" android:startY="68"
                android:endX="50" android:endY="68">
                <item android:offset="0.0" android:color="#C9A774" />
                <item android:offset="0.85" android:color="#B48C5A" />
                <item android:offset="1.0" android:color="#7A5A30" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Right page — mirror gradient -->
    <path
        android:pathData="M80,62 C78,57 70,53 58,55 L58,82 C70,80 78,82 80,84 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="58" android:startY="68"
                android:endX="80" android:endY="68">
                <item android:offset="0.0" android:color="#7A5A30" />
                <item android:offset="0.15" android:color="#B48C5A" />
                <item android:offset="1.0" android:color="#C9A774" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Spine — a thin gilt band binding the pages -->
    <path
        android:fillColor="#7A5A30"
        android:pathData="M50,55 L58,55 L58,82 L50,82 Z" />
    <path
        android:fillColor="#3A2614"
        android:pathData="M53,55 L55,55 L55,82 L53,82 Z" />

    <!-- Three suggested lines of text on each page — fine gilt rules
         that read as "open book with words on it" at any density. -->
    <path
        android:strokeColor="#7AE0C8A0"
        android:strokeWidth="0.9"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M32,65 L46,64 M32,69 L45,68 M32,73 L44,72 M32,77 L43,76" />
    <path
        android:strokeColor="#7AE0C8A0"
        android:strokeWidth="0.9"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M62,64 L76,65 M63,68 L76,69 M64,72 L76,73 M65,76 L76,77" />

    <!-- Sound-wave arcs — ascending from the spine, each broader than
         the last, fading from warm brass to bright gilt as they rise.
         Slight curvature exaggerated so the motif reads as audio rising
         from the page even at launcher-tile density. -->
    <path
        android:strokeWidth="2.6"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M44,48 Q54,40 64,48">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="linear"
                android:startX="44" android:startY="48"
                android:endX="64" android:endY="48">
                <item android:offset="0.0" android:color="#B48C5A" />
                <item android:offset="0.5" android:color="#C9A774" />
                <item android:offset="1.0" android:color="#B48C5A" />
            </gradient>
        </aapt:attr>
    </path>
    <path
        android:strokeWidth="2.6"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M40,40 Q54,28 68,40">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="linear"
                android:startX="40" android:startY="40"
                android:endX="68" android:endY="40">
                <item android:offset="0.0" android:color="#C9A774" />
                <item android:offset="0.5" android:color="#E0C8A0" />
                <item android:offset="1.0" android:color="#C9A774" />
            </gradient>
        </aapt:attr>
    </path>
    <path
        android:strokeWidth="2.6"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M36,32 Q54,16 72,32">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="linear"
                android:startX="36" android:startY="32"
                android:endX="72" android:endY="32">
                <item android:offset="0.0" android:color="#A0E0C8A0" />
                <item android:offset="0.5" android:color="#FFE0C8A0" />
                <item android:offset="1.0" android:color="#A0E0C8A0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Candle flame at the apex of the arcs — Library Nocturne's
         signature mote. A teardrop with a brass-to-bright-gilt vertical
         gradient, plus a tiny dark wick stub at its base. Anchored at
         y=20 so the whole flame stays inside the 72dp safe zone even
         under aggressive launcher masks. -->
    <path
        android:pathData="M54,20 C50,20 49,25 51,27 C52,28 50,29 51,30 C52,31 56,31 57,30 C58,29 56,28 57,27 C59,25 58,20 54,20 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="54" android:startY="20"
                android:endX="54" android:endY="31">
                <item android:offset="0.0" android:color="#FFF6E2" />
                <item android:offset="0.55" android:color="#E0C8A0" />
                <item android:offset="1.0" android:color="#B48C5A" />
            </gradient>
        </aapt:attr>
    </path>
    <!-- Wick stub — barely visible, anchors the flame to the world -->
    <path
        android:fillColor="#3A2614"
        android:strokeColor="#3A2614"
        android:strokeWidth="0.6"
        android:pathData="M54,31 L54,33" />

    <!-- Two tiny brass embers floating beside the upper arc -->
    <path
        android:fillColor="#A0E0C8A0"
        android:pathData="M30,24 m-0.7,0 a0.7,0.7 0 1,0 1.4,0 a0.7,0.7 0 1,0 -1.4,0" />
    <path
        android:fillColor="#80C9A774"
        android:pathData="M78,26 m-0.6,0 a0.6,0.6 0 1,0 1.2,0 a0.6,0.6 0 1,0 -1.2,0" />

</vector>
