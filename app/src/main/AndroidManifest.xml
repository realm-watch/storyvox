<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!--
      In-app VoxSherpa installer: storyvox downloads the fork APK from GitHub
      Releases and launches Android's package-installer UI. The user still
      confirms the install (Android won't let a non-system app install
      silently), but they don't have to leave storyvox to find the file.
    -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <!--
      Lets ACTION_UNINSTALL_PACKAGE and ACTION_DELETE be triggered against
      VoxSherpa from inside storyvox so the user can clear an upstream-signed
      build before installing the differently-signed fork. Android still
      shows the user a confirmation dialog; this just allows us to launch it.
    -->
    <uses-permission android:name="android.permission.REQUEST_DELETE_PACKAGES" />

    <!--
      Android 11+ package visibility: without these, queryIntentServices(TTS_SERVICE)
      returns nothing and TextToSpeech can't bind to VoxSherpa. The package name is
      pinned via BuildConfig.VOXSHERPA_PACKAGE in :core-playback.
    -->
    <queries>
        <intent>
            <action android:name="android.intent.action.TTS_SERVICE" />
        </intent>
        <package android:name="com.CodeBySonu.VoxSherpa" />
    </queries>

    <application
        android:name=".StoryvoxApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.Material.NoActionBar"
        tools:targetApi="35">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:configChanges="orientation|screenSize|smallestScreenSize|screenLayout|keyboard|keyboardHidden|navigation|uiMode">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Open-with: royalroad.com/fiction/{id} -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" />
                <data android:host="www.royalroad.com" android:pathPrefix="/fiction/" />
                <data android:host="royalroad.com" android:pathPrefix="/fiction/" />
            </intent-filter>
        </activity>

        <!-- Disable default WorkManager init so Hilt's Configuration.Provider takes over. -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <!--
          FileProvider for the in-app VoxSherpa installer: exposes the
          downloaded APK in cacheDir/installs/ to Android's package-installer
          activity via a content:// URI (raw file:// URIs have been blocked
          for installs since N).
        -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.installs"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths_installs" />
        </provider>

    </application>

</manifest>
