<!--
  Storyvox status-bar / notification small icon.

  An open book glyph at 24dp. Drawn as solid white shapes — Android tints small
  icons monochrome automatically (system colorControlNormal on the lock screen,
  system status bar tint elsewhere). Do not add fillColor variants here; the
  framework will recolor them and any non-white pixels become muddy.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <!-- Spine + left page -->
    <path
        android:fillColor="@android:color/white"
        android:pathData="M3,5.5C3,4.7 3.7,4 4.5,4H11V18.5L4.5,18.5C3.7,18.5 3,17.8 3,17V5.5ZM5,6V16.5L9.5,16.5V6L5,6Z" />
    <!-- Right page -->
    <path
        android:fillColor="@android:color/white"
        android:pathData="M13,4H19.5C20.3,4 21,4.7 21,5.5V17C21,17.8 20.3,18.5 19.5,18.5H13V4ZM14.5,6V16.5L19,16.5V6L14.5,6Z" />
    <!-- Page lines (left) -->
    <path
        android:fillColor="@android:color/white"
        android:pathData="M6,8H8.5V8.75H6V8ZM6,10H8.5V10.75H6V10ZM6,12H8.5V12.75H6V12Z" />
    <!-- Page lines (right) -->
    <path
        android:fillColor="@android:color/white"
        android:pathData="M15.5,8H18V8.75H15.5V8ZM15.5,10H18V10.75H15.5V10ZM15.5,12H18V12.75H15.5V12Z" />
    <!-- Sound wave dot under the book — hint that this is audio, not just text -->
    <path
        android:fillColor="@android:color/white"
        android:pathData="M12,20.5m-1,0a1,1 0 1,0 2,0a1,1 0 1,0 -2,0" />
</vector>
