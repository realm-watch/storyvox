<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- KVMR streams over HTTPS; no INTERNET permission is technically
         required at the manifest layer of this module (the request
         happens inside Media3 / ExoPlayer in :core-playback whose own
         manifest carries it). Declared anyway for symmetry with other
         source modules + future Live-stream metadata calls (track
         titles, "Now playing" lookups against KVMR's API). -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

</manifest>
